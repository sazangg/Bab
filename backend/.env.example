DATABASE_URL=sqlite+aiosqlite:///./bab.db
BAB_ENVIRONMENT=development
# Generate your own value with:
# uv run python -c "import secrets; print(secrets.token_urlsafe(48))"
BAB_SECRET_KEY=change-me-to-at-least-32-characters
# Generate your own value with:
# uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BAB_ENCRYPTION_KEY=
# Optional dedicated key for the tamper-evident audit-log HMAC. Set this to a stable,
# secret value (distinct from BAB_SECRET_KEY) so the JWT signing key can be rotated
# without invalidating historical audit-chain verification. Blank falls back to
# BAB_SECRET_KEY (legacy behavior).
BAB_AUDIT_SIGNING_KEY=
BAB_PROXY_MAX_BODY_BYTES=1000000
# When false (default), provider base URLs that resolve to private/loopback/link-local
# addresses are rejected (SSRF guard). Set true only for trusted single-tenant
# deployments that must target an internal model server.
BAB_ALLOW_PRIVATE_PROVIDER_URLS=false
# Authentication rate limiting is disabled by default. When enabled, Redis is
# required and becomes a readiness dependency.
BAB_REDIS_URL=
BAB_RATE_LIMIT_ENABLED=false
BAB_RATE_LIMIT_FAIL_CLOSED=true
# Provider circuit state defaults to process-local memory. Use redis for shared
# circuit state in multi-worker deployments.
BAB_PROVIDER_RUNTIME_STATE_BACKEND=memory
# Metrics are enabled locally without auth. In production, either set
# BAB_METRICS_BEARER_TOKEN or disable metrics.
BAB_METRICS_ENABLED=true
BAB_METRICS_BEARER_TOKEN=
# App/admin console origin used for production invite links and cross-site cookie
# origin checks. Required in production; local development may leave it blank.
BAB_PUBLIC_APP_URL=
# Cross-site refresh cookies require SameSite=None, Secure=true, and BAB_PUBLIC_APP_URL.
BAB_REFRESH_COOKIE_SECURE=
BAB_REFRESH_COOKIE_SAMESITE=lax
BAB_REFRESH_COOKIE_DOMAIN=
# Optional retention intent only. Blank means retain records indefinitely; no deletion job runs.
BAB_USAGE_RETENTION_DAYS=
BAB_ACTIVITY_RETENTION_DAYS=

# Local development seed. Used only when the database has no users.
BAB_DEFAULT_ORGANIZATION_NAME=Default Organization
BAB_DEFAULT_TEAM_NAME=Default Team
BAB_DEFAULT_ADMIN_EMAIL=admin@example.com
BAB_DEFAULT_ADMIN_PASSWORD=admin-password-change-me

# Optional live provider integration smoke. These are only used by the gated test:
# uv run pytest tests/integration/test_gateway_flow.py -q
BAB_RUN_LIVE_OPENAI_TESTS=false
OPENAI_API_KEY=
BAB_LIVE_OPENAI_MODEL=
